{
  "name": "rv-image-optimize",
  "version": "3.0.0",
  "type": "module",
  "description": "图片优化工具和懒加载组件，支持多种CDN和自动格式转换",
  "main": "./dist/image-optimize.cjs",
  "module": "./dist/image-optimize.es.js",
  "files": [
    "bin",
    "dist",
    "lib",
    "README.md",
    "REACT_MIGRATION_3X.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/image-optimize.es.js",
      "require": "./dist/image-optimize.cjs",
      "default": "./dist/image-optimize.es.js"
    },
    "./utils-only": {
      "import": "./dist/image-optimize-utils.es.js",
      "require": "./dist/image-optimize-utils.cjs",
      "default": "./dist/image-optimize-utils.es.js"
    },
    "./lossless": "./lib/losslessCompress.js",
    "./node-compress": "./lib/nodeCompress.js",
    "./upload-core": "./lib/uploadCore.js",
    "./upload": "./lib/uploadPipeline.js",
    "./cache": "./lib/imageCache.js",
    "./LazyImage": {
      "import": "./dist/lazy-image.es.js",
      "require": "./dist/lazy-image.cjs",
      "default": "./dist/lazy-image.es.js"
    },
    "./ProgressiveImage": {
      "import": "./dist/progressive-image.es.js",
      "require": "./dist/progressive-image.cjs",
      "default": "./dist/progressive-image.es.js"
    },
    "./styles": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build-utils-only.js",
    "build:static": "vite build --mode static",
    "cli": "node ./bin/rv-image-optimize.js",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "rv-image-optimize": "./bin/rv-image-optimize.js"
  },
  "keywords": [
    "image",
    "optimize",
    "lazy-load",
    "cdn",
    "webp",
    "avif",
    "responsive",
    "react",
    "component"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "gitee",
    "url": "https://gitee.com/imageOptimize/image-optimize.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
