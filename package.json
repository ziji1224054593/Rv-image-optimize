{
  "name": "rv-image-optimize",
  "version": "3.0.11",
  "type": "module",
  "description": "图片优化工具和懒加载组件，支持多种CDN和自动格式转换",
  "main": "./dist/image-optimize.cjs",
  "module": "./dist/image-optimize.es.js",
  "types": "./types/index.d.ts",
  "files": [
    "bin",
    "dist",
    "types",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/image-optimize.es.js",
      "require": "./dist/image-optimize.cjs",
      "default": "./dist/image-optimize.es.js"
    },
    "./utils-only": {
      "types": "./types/index.d.ts",
      "import": "./dist/image-optimize-utils.es.js",
      "require": "./dist/image-optimize-utils.cjs",
      "default": "./dist/image-optimize-utils.es.js"
    },
    "./lossless": {
      "types": "./types/index.d.ts",
      "import": "./dist/lossless.es.js",
      "default": "./dist/lossless.es.js"
    },
    "./node-compress": {
      "types": "./types/index.d.ts",
      "import": "./dist/node-compress.es.js",
      "require": "./dist/node-compress.cjs",
      "default": "./dist/node-compress.es.js"
    },
    "./vite-plugin": {
      "types": "./types/index.d.ts",
      "import": "./dist/vite-plugin.es.js",
      "default": "./dist/vite-plugin.es.js"
    },
    "./webpack-plugin": {
      "types": "./types/index.d.ts",
      "import": "./dist/webpack-plugin.es.js",
      "require": "./dist/webpack-plugin.cjs",
      "default": "./dist/webpack-plugin.es.js"
    },
    "./upload-core": {
      "types": "./types/index.d.ts",
      "import": "./dist/upload-core.es.js",
      "default": "./dist/upload-core.es.js"
    },
    "./upload": {
      "types": "./types/index.d.ts",
      "import": "./dist/upload.es.js",
      "default": "./dist/upload.es.js"
    },
    "./cache": {
      "types": "./types/index.d.ts",
      "import": "./dist/cache.es.js",
      "default": "./dist/cache.es.js"
    },
    "./LazyImage": {
      "types": "./types/index.d.ts",
      "import": "./dist/lazy-image.es.js",
      "default": "./dist/lazy-image.es.js"
    },
    "./ProgressiveImage": {
      "types": "./types/index.d.ts",
      "import": "./dist/progressive-image.es.js",
      "default": "./dist/progressive-image.es.js"
    },
    "./styles": {
      "types": "./types/index.d.ts",
      "default": "./dist/style.css"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-package.js",
    "build:static": "vite build --mode static",
    "cli": "node ./bin/rv-image-optimize.js",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "rv-image-optimize": "bin/rv-image-optimize.js"
  },
  "keywords": [
    "image",
    "optimize",
    "lazy-load",
    "cdn",
    "webp",
    "avif",
    "responsive",
    "react",
    "component"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "gitee",
    "url": "https://gitee.com/imageOptimize/image-optimize.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "directories": {
    "example": "example",
    "lib": "lib"
  }
}
